# Copy this file to .env and fill in your actual keys.
# .env is git-ignored — never commit real keys.

# Fal.ai — image generation (Flux Kontext)
# Get from https://fal.ai/dashboard/keys
FAL_KEY=

# Photoroom — background removal (optional but recommended)
# Get from https://www.photoroom.com/api/dashboard/api-keys
PHOTOROOM_KEY=

# Anthropic — Claude for brief parsing and vision QA
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter — unified API for routing tasks to the cheapest capable model
# Get from https://openrouter.ai/keys
# Used for: product detection (Gemini Flash), brief parsing (Haiku)
# QA scoring stays on Claude Sonnet direct for reliability
OPENROUTER_API_KEY=
